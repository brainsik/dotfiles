#!/usr/bin/env bash
#
# Installs the latest unknown-linux binary from the give GitHub repo.
#
set -eu -o pipefail

if [[ -z "${1:-}" ]]; then
	echo "Usage: $0 <user/repo>"
	exit 1
fi
repo="${LI_REPO:-$1}"
libc="${LI_LIBC:-$2}"

arch=$(uname -m)
name=$(basename "$repo")
ext=${LI_EXT:-gz}

echo "💾 Installing $name …"
tmpdir=$(mktemp -d)
file="$tmpdir/$name.tar.$ext"

dl_tag=$(curl -fsSL "https://api.github.com/repos/$repo/releases/latest" | python3 -c "import json,sys;obj=json.load(sys.stdin);print(obj['tag_name']) if 'tag_name' in obj else sys.exit(f\"Error: {obj['message']}\");")
tag="-$dl_tag"
if [[ -n "${LI_NOTAG:-}" ]]; then
    tag=""
fi

url="https://github.com/$repo/releases/download/$dl_tag/$name$tag-$arch-unknown-linux-$libc.tar.$ext"
curl -fL --progress-bar --output "$file" "$url"

tar -xaof "$file" -C "$tmpdir"

if [[ -s "$tmpdir/$name$tag-$arch-unknown-linux-$libc/$name" ]]; then
    binpath="$tmpdir/$name$tag-$arch-unknown-linux-$libc/$name"
elif [[ -s "$tmpdir/$name" ]]; then
    binpath="$tmpdir/$name"
else
    echo "💥 Couldn't find binary in $tmpdir:"
    ls -oh "$tmpdir"
    exit 1
fi
mv "$binpath" "$HOME/bin/$name"
rm -rf "$tmpdir"

"$HOME/bin/$name" --version
